{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=DevLearningHubDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "Issuer": "DevLearningHub",
    "Audience": "DevLearningHubUsers",
    "SecretKey": "THIS_IS_A_DEMO_SECRET_KEY_CHANGE_IT_IN_PRODUCTION_123456789",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "FileStorage": {
    "RootPath": "uploads",
    "PublicBaseUrl": "/uploads"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ObjectStorage": {
    "Provider": "MinIO",
    "FallbackToLocal": true,
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".webp",
      ".pdf",
      ".doc",
      ".docx",
      ".txt",
      ".zip"
    ],
    "AllowedImageExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".webp"
    ],
    "LocalRootPath": "uploads",
    "LocalPublicBaseUrl": "/uploads",
    "MinIO": {
      "Endpoint": "http://localhost:9000",
      "PublicBaseUrl": "http://localhost:9000/devlearninghub",
      "AccessKey": "admin",
      "SecretKey": "12345678",
      "Bucket": "devlearninghub",
      "Region": "us-east-1",
      "ForumFolder": "forum"
    }
  }
}