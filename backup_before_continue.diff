diff --git a/client/devlearninghub-client/src/app/core/interceptors/auth.interceptor.ts b/client/devlearninghub-client/src/app/core/interceptors/auth.interceptor.ts
index 918d8879..6d761d36 100644
--- a/client/devlearninghub-client/src/app/core/interceptors/auth.interceptor.ts
