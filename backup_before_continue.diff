+<div class="page">
+  <div class="page-head">
+    <div class="page-title">
+      <h1>Learning Roadmap</h1>
+      <p>Recommended paths adapt to your quiz history and weaker topics.</p>
+    </div>
+    <a class="btn btn-primary" routerLink="/learner/learning">Continue Learning</a>
+  </div>
+
+  <div class="alert" *ngIf="error">{{error}}</div>
+  <div class="empty-state" *ngIf="loading">Loading roadmap...</div>
+
+  <div class="card card-pad" *ngIf="!loading && priorityTopics.length">
+    <h3>Recommended Next</h3>
+    <div class="action-row">
+      <span class="badge badge-blue" *ngFor="let topic of priorityTopics">{{topic}}</span>
+    </div>
+  </div>
+
+  <div class="grid grid-3" *ngIf="!loading && paths.length">
+    <div class="card card-pad roadmap-card hover" *ngFor="let path of paths">
+      <h3>{{path.level}}</h3>
+      <div class="step" *ngFor="let topic of path.topics; let i = index" [class.progress-step]="i === 0">
+        <svg aria-hidden="true" class="icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
+          <circle cx="12" cy="12" r="10"></circle>
+        </svg>
+        <div style="flex:1">
+          <b>{{topic}}</b>
+          <div><span class="badge" [class.badge-blue]="priorityTopics.includes(topic)" [class.badge-gray]="!priorityTopics.includes(topic)">{{priorityTopics.includes(topic) ? 'Recommended' : 'Queued'}}</span></div>
+        </div>
+      </div>
+    </div>
+  </div>
+
+  <div class="empty-state" *ngIf="!loading && !paths.length && !error">No roadmap data yet.</div>
+</div>
