+@Component({
+  selector: 'app-forum',
+  standalone: true,
+  imports: [CommonModule, FormsModule, RouterLink],
+  templateUrl: './forum.component.html'
+})
+export class ForumComponent implements OnInit {
+  posts: any[] = [];
+  tags: any[] = [];
+  keyword = '';
+  tag = 'all';
+  loading = false;
+  error = '';
+  pageIndex = 1;
+  totalPages = 1;
+
